# ============ FRONTEND ============

# Solana RPC endpoint — DO NOT use public RPC in production
# Public endpoint rate-limits aggressively, will break bot and priority fee lookups
# Get a free/paid endpoint from Helius (helius.dev) or Quicknode
VITE_RPC_URL=https://api.mainnet-beta.solana.com

# Fee in basis points (30 = 0.3%)
VITE_FEE_BPS=30

# Birdeye API key (for token pricing)
VITE_BIRDEYE_API_KEY=

# ============ PROGRAMS (update after deployment) ============

# crank.money core program ID
CORE_PROGRAM_ID=
# monke_bananas program ID (burn $CRANK, feed monkes, claim $PEGGED)
MONKE_BANANAS_PROGRAM_ID=
# pegged_bridge program ID
BRIDGE_PROGRAM_ID=
# $PEGGED LST mint
PEGGED_MINT=

# ============ BOT ============

# RPC endpoint for bot (dedicated gRPC-tier endpoint recommended)
RPC_URL=https://api.mainnet-beta.solana.com

# Cheaper Helius RPC key (used by scripts + frontend config)
HELIUS_RPC_URL=

# Geyser/gRPC endpoint (Helius LaserStream recommended)
# Required for real-time price monitoring
GRPC_ENDPOINT=

# Bot wallet — must match config.bot on core program
# WARNING: Never commit this file with a real key. Use BOT_KEYPAIR_PATH for production.
# Option 1: Base58 private key (dev only)
BOT_PRIVATE_KEY=
# Option 2: Path to Solana CLI keypair JSON file (recommended for production)
BOT_KEYPAIR_PATH=

# $CRANK token mint address
BANANAS_MINT=Fr4cqYmSK1n8H1ePkcpZthKTiXWqN14ZTn9zj1Gnpump

# Keeper check interval (ms, default 1hr — adaptive: 30s during Saturday processing)
KEEPER_CHECK_INTERVAL_MS=3600000

